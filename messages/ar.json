  "legal": {
    "contactWhatsapp": "تواصل معنا عبر واتساب",
    "privacy": {
      "eyebrow": "قانوني",
      "title": "سياسة الخصوصية",
      "intro": "توضح هذه الصفحة المعلومات الأساسية التي تستخدمها Sabrina Turizm للرد على الاستفسارات وترتيب خدمات السفر.",
      "section1Heading": "المعلومات التي نجمعها",
      "section1Body": "عند تواصلك معنا، قد نستلم اسمك، وبيانات الاتصال، وتواريخ السفر، وحجم المجموعة، وتفضيلات الوجهة، وملاحظات الحجز، والرسائل ذات الصلة.",
      "section2Heading": "كيف نستخدمها",
      "section2Body": "نستخدم هذه المعلومات للرد على استفساراتك، وإعداد عروض الأسعار، وتنسيق خدمات السفر، وإدارة الحجوزات، وتقديم دعم العملاء.",
      "section3Heading": "الطلبات",
      "section3Body": "للاستفسار عن معلوماتك أو طلب تصحيح أو حذف عند الاقتضاء، تواصل معنا مباشرة عبر واتساب أو البريد الإلكتروني."
    },
    "terms": {
      "eyebrow": "قانوني",
      "title": "الشروط والأحكام",
      "intro": "تصف هذه الشروط العامة كيفية التعامل مع الاستفسارات والحجوزات. تُشارَك تفاصيل الحجز المؤكدة مع كل ضيف قبل الدفع.",
      "section1Heading": "عروض الأسعار والتوفر",
      "section1Body": "أسعار الموقع والأمثلة هي نقاط انطلاق ما لم يُذكر خلاف ذلك. يُؤكَّد التوفر النهائي والمشتملات والمسار والتسعير كتابياً.",
      "section2Heading": "مسؤولية الضيف",
      "section2Body": "يتحمل الضيوف مسؤولية تقديم تواريخ السفر وأعداد الركاب وتفاصيل الإقامة ومعلومات الرحلات وأي متطلبات خاصة قبل التأكيد.",
      "section3Heading": "تغييرات الخدمة",
      "section3Body": "قد تكون تغييرات المسار أو التوقيت أو الفندق أو المركبة أو المرشد ضرورية بسبب التوفر أو الطقس أو حركة المرور أو الإغلاقات المحلية أو المتطلبات التشغيلية."
    },
    "cancellation": {
      "eyebrow": "قانوني",
      "title": "سياسة الإلغاء",
      "intro": "قد تختلف شروط الإلغاء حسب الفندق والمركبة والمرشد والمسار والموسم والمورد. تُؤكَّد الشروط المنطبقة مع كل حجز.",
      "section1Heading": "قبل التأكيد",
      "section1Body": "يمكنك تغيير الاستفسار أو إيقافه قبل تأكيد الحجز. لا تُحتجز أي خدمة حتى يُتفق على تفاصيل التأكيد كتابياً.",
      "section2Heading": "بعد التأكيد",
      "section2Body": "بمجرد تأكيد الحجز، قد تُطبَّق رسوم إلغاء وفقاً لقواعد المورد والتوقيت والخدمات المدفوعة مسبقاً والحجوزات غير القابلة للاسترداد.",
      "section3Heading": "كيفية الإلغاء",
      "section3Body": "تواصل مع Sabrina Turizm مباشرة عبر واتساب أو البريد الإلكتروني مع تفاصيل حجزك. سنؤكد شروط الإلغاء المنطبقة على حجزك."
    }
  },
